# Copy this file to .env.local and fill in the real values from your
# Supabase project (Project Settings -> API).
#
# NEXT_PUBLIC_ variables are exposed to the browser. Only the anon/publishable
# key belongs here — never the service_role secret key.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key
